{
	"bhl": {
		"api_key": "STRING"
	},
	"exiftool": "/usr/bin/exiftool",
	"max_memory": "1536M",
	"cache": {
		"lifetime": 2,
		"paths": {
			"pdf": "./cache/pdf",
			"image": "./cache/image",
			"resize": "./cache/resize",
			"json": "./cache/json",
			"djvu": "./cache/djvu",
			"hocr": "./cache/hocr"
		}
	},
	"paths": {
		"tmp": "./tmp",
		"output": "./output",
		"tesseract": "/usr/bin/tesseract",
		"tessdata": "/usr/share/tesseract/tessdata_best-main"
	},
	"image": {
		"resize": "0.50"
	},
	"mq": {
		"hostname": "RABBITMQ.EXAMPLE.COM",
		"port": "5672",
		"username": "USER",
		"password": "PASS",
		"queue_name": "Q-NAME",
		"error_queue_name": "Q-NAME-ERROR"
	},
	"logging": {
		"filename": "./log/pdf-generator.log"
	},
	"verbose": 0
}
